# Generated Team Nexus profile config for {{ profile }}.
# Managed by future profile bootstrap tooling. Do not place secrets here.

terminal:
  cwd: {{ workspace_cwd }}

checkpoints:
  enabled: {{ checkpoints_enabled }}
  max_snapshots: 50

gateway:
  enabled: {{ gateway_enabled }}

kanban:
  enabled: true

skills:
  external_dirs:
    - {{ repo_root }}/shared/skills

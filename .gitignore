# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!*.env.example

# -----------------------------------------------------------------------------
# Hermes runtime state and user-sensitive profile data
# -----------------------------------------------------------------------------
# Profile-driven runtime staging/output may contain profile-local env, auth,
# sessions, memory, logs, checkpoints, Kanban databases, downloaded files, and
# task/customer data. Canonical source lives under profiles/, shared/, docs/,
# scripts/, and docker-compose.profiles.yml.
runtime/

# -----------------------------------------------------------------------------
# Local-only overrides
# -----------------------------------------------------------------------------
*.local
*.local.*
config.local.yaml
profiles/*/config.local.yaml


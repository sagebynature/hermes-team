# Secrets for Lumen (UX / Design Lead). Do not commit real values.
# Copy this file to .env or edit .env in place.

# Model providers
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Discord gateway token for this specific bot/agent
DISCORD_BOT_TOKEN=

# Optional integrations
GITHUB_TOKEN=
GATEWAY_API_KEY=
# Optional tool access used by `hermes doctor` for full availability.
# Leave blank unless you use these integrations. At least one web-search key
# (EXA, PARALLEL, TAVILY, or FIRECRAWL) enables the web toolset.
EXA_API_KEY=
PARALLEL_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
TINKER_API_KEY=
WANDB_API_KEY=

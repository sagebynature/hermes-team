# Team Nexus dashboard reverse proxy.
# Exposes all Hermes dashboards on one localhost Nginx port:
#   http://127.0.0.1:${NGINX_PORT:-9130}/<agent>/
#
# Hermes dashboard currently assumes it is served at /. These locations strip
# the /<agent>/ prefix upstream, then rewrite absolute asset/API/router paths
# in returned HTML/JS/CSS/JSON so each SPA stays under its agent prefix.

map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

server {
  listen 80;
  server_name _;
  server_tokens off;
  absolute_redirect off;
  client_max_body_size 25m;
  proxy_read_timeout 3600s;
  proxy_send_timeout 3600s;

  location = / {
    return 302 /{{default_route}}/;
  }

  location = /healthz {
    add_header Content-Type text/plain;
    return 200 'ok\n';
  }

{{dashboard_shortcuts}}

{{dashboard_locations}}
}

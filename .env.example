# Shared secrets for all Team Nexus agents. Do not commit real values.
# Copy this file to .env in the repo root and fill in the keys you need.
# docker-compose.yml loads this same ./.env file into every agent container.

# Model providers
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Shared gateway credentials. If you run multiple gateway bots, keep only the
# shared/default values here and put provider-specific auth state in each
# agent's mounted home via `docker compose run --rm <agent> gateway setup`.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=
DISCORD_STATUS_WEBHOOK_URL=
DISCORD_HANDOFFS_WEBHOOK_URL=

# Optional dashboard reverse-proxy port. With the dashboard profile running, open
# http://127.0.0.1:${NGINX_PORT}/atlas, /vega, /scout, /forge, /lumen, /blitz, /ledger, or /sentinel.
NGINX_PORT=9130

# Optional dispatcher tuning. Defaults are 60 seconds, 1 task per pass, and 900 seconds per worker.
KANBAN_DISPATCH_INTERVAL=60
KANBAN_DISPATCH_MAX_TASKS=1
KANBAN_DISPATCH_WORKER_TIMEOUT=900

# Optional integrations
GITHUB_TOKEN=
GATEWAY_API_KEY=
CONTEXT7_API_KEY=

# Optional tool access used by `hermes doctor` for full availability.
# Leave blank unless you use these integrations. At least one web-search key
# (EXA, PARALLEL, TAVILY, or FIRECRAWL) enables the web toolset.
EXA_API_KEY=
PARALLEL_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
TINKER_API_KEY=
WANDB_API_KEY=

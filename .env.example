# Shared secrets for the Team Nexus profile-driven runtime. Do not commit real values.
# Copy this file to .env in the repo root and fill in the keys you need.
# docker-compose.profiles.yml loads this same ./.env file into runtime services.

# Model providers
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Shared Discord gateway/status credentials. Atlas is the v1 Discord-facing
# gateway; specialists coordinate through Kanban unless a task explicitly opts
# into direct Discord reply.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=
DISCORD_FREE_RESPONSE_CHANNELS=
DISCORD_ALLOWED_CHANNELS=
DISCORD_STATUS_WEBHOOK_URL=
DISCORD_HANDOFFS_WEBHOOK_URL=
DISCORD_COMMAND_SYNC_POLICY=safe

# Host UID/GID for Linux bind mounts. The Makefile exports these automatically
# from `id -u` / `id -g`; set them explicitly when running docker compose
# directly or when deploying under a service account.
# TEAM_NEXUS_UID=1000
# TEAM_NEXUS_GID=1000

# Optional host bind address and profile dashboard port. Keep the default
# loopback bind for local-only access. Set TEAM_NEXUS_BIND_ADDRESS=0.0.0.0
# to expose gateway/dashboard ports to other devices on your local network.
TEAM_NEXUS_BIND_ADDRESS=127.0.0.1
# With the dashboard profile running, open:
# http://${TEAM_NEXUS_BIND_ADDRESS:-127.0.0.1}:${TEAM_NEXUS_DASHBOARD_PORT:-8180}
TEAM_NEXUS_DASHBOARD_PORT=8180

# Optional dispatcher tuning. Defaults are 60 seconds, 1 concurrent task per pass, 900 seconds per worker,
# and Atlas task dispatch enabled so mission synthesis tasks are picked up.
KANBAN_DISPATCH_INTERVAL=60
KANBAN_DISPATCH_MAX_TASKS=1
KANBAN_DISPATCH_WORKER_TIMEOUT=900
KANBAN_DISPATCH_INCLUDE_ATLAS=1

# Optional integrations
GITHUB_TOKEN=
GATEWAY_API_KEY=
CONTEXT7_API_KEY=

# Google Workspace CLI (`gws`) credentials. Copy your credential JSON to an
# ignored runtime path such as runtime/hermes/secrets/google-workspace-credentials.json,
# then point gws at the in-container path below. docker-compose.profiles.yml
# already mounts ./runtime/hermes at /opt/data.
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/opt/data/secrets/google-workspace-credentials.json

# Optional tool access used by `hermes doctor` for full availability.
# Leave blank unless you use these integrations. At least one web-search key
# (EXA, PARALLEL, TAVILY, or FIRECRAWL) enables the web toolset.
EXA_API_KEY=
PARALLEL_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
TINKER_API_KEY=
WANDB_API_KEY=
